# Formspree endpoint for the early-access form (src/components/sections/EarlyAccess.tsx).
# Create a form at https://formspree.io and paste its endpoint URL here.
# Note: VITE_ vars are bundled into the client, so this value is public (not a secret).
# Copy this file to `.env` and set the real value locally; also add it to your
# Vercel project's Environment Variables.
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id
