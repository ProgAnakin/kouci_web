{
  "name": "kouci-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kouci — Master Every Play. Landing page for the water polo tactical & statistical analysis app.",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/gen-seo.mjs && tsc -b && vite-react-ssg build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc -b && eslint . && prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gsap": "^3.12.5",
    "lenis": "^1.3.24",
    "maath": "^0.10.8",
    "marked": "^18.0.5",
    "motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "three": "^0.169.0",
    "vite-react-ssg": "^0.9.1-beta.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.4.47",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.10"
  }
}
